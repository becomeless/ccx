{
  "name": "@cc-x/cc-x",
  "version": "0.4.5",
  "description": "Claude Code API 切换器（命令 xx）：在官方账号与第三方 Anthropic 兼容 API 间切换，纯环境变量、不碰 Claude Code 配置文件。",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "api",
    "switcher",
    "cli",
    "deepseek",
    "glm"
  ],
  "homepage": "https://github.com/becomeless/cc-x#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/becomeless/cc-x.git"
  },
  "license": "MIT",
  "author": "becomeless",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "xx": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "!dist/release/**",
    "!dist/**/*.exe",
    "!dist/**/*.zip",
    "!dist/**/*.md",
    "!dist/**/*.txt",
    "!dist/**/LICENSE",
    "!dist/**/presets.json",
    "presets.json",
    "README.md",
    "README.en.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "string-width": "^7.2.0",
    "which": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/which": "^3.0.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
